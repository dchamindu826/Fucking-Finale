generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  firstName      String
  lastName       String
  phone          String   @unique
  whatsapp       String?
  optionalPhone  String?
  nic            String?
  addressHouseNo String?
  addressStreet  String?
  city           String?
  district       String?
  password       String
  role           String   @default("Student")
  department     String?
  businessType   String?
  
  image          String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  payments        Payment[] 
  assignedLeads   Lead[]          @relation("AssignedLeads")
  sentMessages    ChatMessage[]   @relation("SentMessages")
  autoAssignQuota AutoAssignQuota?
}

model Business {
  id                               Int         @id @default(autoincrement())
  name                             String
  category                         String
  medium                           String      @default("Sinhala")
  description                      String?
  logo                             String?
  streams                          String?
  isDiscountEnabledForInstallments Int         @default(0)
  head_manager_id                  Int?
  ass_manager_id                   Int?
  status                           Int         @default(1)
  batches                          Batch[]
  createdAt                        DateTime    @default(now())
  
  // 🔥 FIX: Corrected relation name to CrmSettings (with 's') 🔥
  crmSettings                      CrmSettings? @relation(fields: [crmSettingId], references: [id])
  crmSettingId                     Int?
  
  autoReplies                      AutoReply[]
  payments                         Payment[]
}

model Batch {
  id          Int      @id @default(autoincrement())
  name        String
  logo        String?
  type        Int      @default(1)
  itemOrder   Int      @default(1)
  description String?
  status      Int      @default(1)
  businessId  Int
  business    Business @relation(fields: [businessId], references: [id])
  groups      Group[]
  createdAt   DateTime @default(now())

  payments    Payment[]
  lecturers   String?   @db.Text
}

model Group {
  id             Int      @id @default(autoincrement())
  name           String
  type           Int      @default(1)
  itemOrder      Int      @default(1)
  discount_rules String?  @db.Text
  batchId        Int
  batch          Batch    @relation(fields: [batchId], references: [id])
  courses        Course[]
  createdAt      DateTime @default(now())
  
  payments       Payment[] 
}

model Course {
  id                 Int      @id @default(autoincrement())
  name               String
  code               String?
  stream             String?
  streams            String?
  description        String?  @db.Text
  itemOrder          Int      @default(1)
  courseType         Int      @default(1)
  price              Float    @default(0)
  groupPrices        String?  @db.Text
  
  isDiscountExcluded Boolean  @default(false) 
  lecturerName       String?

  groupId            Int?
  group              Group?   @relation(fields: [groupId], references: [id])
  createdAt          DateTime @default(now())
}

model Installment {
  id           Int      @id @default(autoincrement())
  batchId      Int
  subjectCount Int
  details      String   @db.Text
  createdAt    DateTime @default(now())
}

model Post {
  id          Int      @id @default(autoincrement())
  title       String
  caption     String   @db.Text
  image       String?
  business_id BigInt?
  batch_id    BigInt?
  created_at  DateTime @default(now())
}

model ContentGroup {
  id         Int       @id @default(autoincrement())
  title      String
  type       Int
  itemOrder  Int       @default(1)
  batchId    Int
  courseCode String?
  createdAt  DateTime  @default(now())
  contents   Content[]
}

model Content {
  id             Int           @id @default(autoincrement())
  title          String
  contentType    String
  link           String?
  fileName       String?
  meetingId      String?
  date           DateTime?
  startTime      String?
  endTime        String?
  paperTime      Int?
  questionCount  Int?
  isFree         Boolean       @default(false)
  contentGroupId Int?
  group          ContentGroup? @relation(fields: [contentGroupId], references: [id])
  batchId        Int
  courseId       Int
  createdAt      DateTime      @default(now())
}

model ContentCourse {
  id         Int      @id @default(autoincrement())
  content_id Int
  course_id  BigInt
  type       Int
  itemOrder  String   @default("0")
  created_at DateTime @default(now())
}

model Payment {
  id             Int       @id @default(autoincrement())
  amount         Float     @default(0)
  payment_type   Int       @default(1) // 1=Monthly, 2=Installment, 3=Full
  method         String?   @default("Slip")
  status         Int       @default(0) // 0=Pending, 1=Approved, 2=Rejected, 3=Non Paid, 4=Post Pay
  slip_image     String?
  post_pay_days  Int?      @default(0)

  due_date       DateTime? 
  installment_no Int       @default(1) 
  valid_until    DateTime? 

  created_at     DateTime  @default(now())

  studentId      Int?
  student        User?     @relation(fields: [studentId], references: [id])
  businessId     Int?
  business       Business? @relation(fields: [businessId], references: [id])
  batchId        Int?
  batch          Batch?    @relation(fields: [batchId], references: [id])
  
  groupId        Int?
  group          Group?    @relation(fields: [groupId], references: [id])
  
  subjects       String?   @db.Text
  remark         String?   @db.Text
}

// ==========================================
// 🔥 CRM MODULE MODELS 🔥
// ==========================================

model CrmSettings {
  id           Int        @id @default(autoincrement())
  businessId   Int
  campaignType String
  metaApiKey   String?    @db.Text
  waId         String?
  waNumId      String?
  geminiKeys   Json?      // Array of API keys
  botMode      String     @default("OFF")
  batchId      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  businesses   Business[] // Opposite relation required by Prisma
}

model AutoReply {
  id             Int        @id @default(autoincrement())
  businessId     Int
  campaignType   String
  stepOrder      Int
  message        String     @db.Text
  attachment     String?
  attachmentType String?
  createdAt      DateTime   @default(now())
  
  business       Business?  @relation(fields: [businessId], references: [id]) // Relation
}

model KnowledgeBase {
  id           Int      @id @default(autoincrement())
  businessId   Int
  campaignType String?
  fileName     String
  fileUrl      String
  content      String   @db.Text
  createdAt    DateTime @default(now())
}

// ================= CRM MODULE MODELS =================

model Lead {
  id             Int           @id @default(autoincrement())
  name           String?
  phone          String        @unique 
  source         String        @default("whatsapp") 
  campaignType   String        @default("FREE_SEMINAR") 
  status         String        @default("NEW") 
  
  assignedTo     Int?          
  assignedUser   User?         @relation("AssignedLeads", fields: [assignedTo], references: [id])
  
  lastMessage    String?       @db.Text
  unreadCount    Int           @default(0) 
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  
  messages       ChatMessage[]

  phase          Int           @default(1)
  callMethod     String?       // direct, whatsapp, 3cx
  callStatus     String        @default("pending") // pending, no_answer, reject, answered
  feedback       String?
  isAutoAssigned Boolean       @default(false)
}

model ChatMessage {
  id         Int      @id @default(autoincrement())
  leadId     Int
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  message    String   @db.Text
  mediaUrl   String?  @db.Text
  mediaType  String?  
  
  direction  String   // "inbound", "outbound"
  senderType String   // "USER", "STAFF", "AI_BOT", "SYSTEM"
  
  senderId   Int?      
  senderName String?  @default("System")
  senderUser User?    @relation("SentMessages", fields: [senderId], references: [id])
  
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  metaMessageId  String?
}

model AutoAssignQuota {
  id          Int      @id @default(autoincrement())
  staffId     Int      @unique
  staff       User     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  quotaAmount Int      @default(0) // Dawasata assign wenna ona gaana
  assigned    Int      @default(0) // Danata assign wela thiyena gaana
  isActive    Boolean  @default(true) // Toggle on/off
  updatedAt   DateTime @updatedAt
}